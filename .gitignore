private/
.env
.envrc

# Composer dependencies — regenerated by `composer install`
/vendor/

# Drupal core and contributed code — managed by Composer
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/

# Scaffold-generated files in web root (recreated by drupal/core-composer-scaffold)
/web/autoload.php
/web/index.php
/web/robots.txt
/web/update.php
/web/web.config
/web/.htaccess

# Drupal public files (stored in Azure Files mount, not in git)
/web/sites/default/files/

# Local settings overrides — never commit
/web/sites/*/settings.local.php
/web/sites/*/services.local.yml

# Config split local overrides
/config/local/

# Build artifacts
*.zip
*.tar.gz
composer.phar

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo